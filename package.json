{
  "name": "dicom-ct-viewer",
  "version": "1.0.0",
  "description": "A web-based DICOM medical imaging viewer (CT, MRI, etc.) with client-side processing for privacy. Supports JPEG Lossless, JPEG 2000, and uncompressed formats via browser-based decoders. Built with vanilla JS frontend and Flask backend for static serving. See docs/CLAUDE.md for architecture details.",
  "main": "app.py",
  "scripts": {
    "desktop:launch": "cd desktop && npm run dev:desktop",
    "desktop:memory:capture": "python3 scripts/desktop-memory-capture.py --ensure-free-mb 1024 --cleanup-path desktop/src-tauri/target",
    "desktop:memory:session": "bash ./scripts/desktop-memory-session.sh",
    "desktop:memory:report": "python3 scripts/desktop-memory-report.py",
    "format": "npm run format:js && npm run format:py && npm run format:rust",
    "format:check": "npm run format:js:check && npm run format:py:check && npm run format:rust:check",
    "format:js": "biome format --write .",
    "format:js:check": "biome format .",
    "format:py": "./scripts/run-ruff.sh format server/",
    "format:py:check": "./scripts/run-ruff.sh format --check server/",
    "format:rust": "cargo fmt --manifest-path desktop/src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path desktop/src-tauri/Cargo.toml --check",
    "lint": "npm run lint:js && npm run lint:py && npm run lint:rust",
    "lint:fix": "npm run lint:js:fix && npm run lint:py:fix",
    "lint:js": "biome lint .",
    "lint:js:fix": "biome lint --write .",
    "lint:py": "./scripts/run-ruff.sh check server/",
    "lint:py:fix": "./scripts/run-ruff.sh check --fix server/",
    "lint:rust": "cargo clippy --locked --manifest-path desktop/src-tauri/Cargo.toml --all-targets -- -D warnings",
    "test": "npx playwright test",
    "worktree:new": "./scripts/agent-worktree-new.sh",
    "worktree:list": "./scripts/agent-worktree-list.sh",
    "worktree:list:all": "./scripts/agent-worktree-list.sh --all",
    "worktree:retire": "./scripts/agent-worktree-retire.sh"
  },
  "keywords": [
    "dicom",
    "medical-imaging",
    "ct-scan",
    "radiology",
    "viewer",
    "healthcare"
  ],
  "author": "Gabriel Casalduc <https://divergent.health/>",
  "license": "MIT",
  "homepage": "https://divergent.health/",
  "dependencies": {
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@playwright/test": "^1.58.0",
    "playwright": "^1.58.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  }
}
