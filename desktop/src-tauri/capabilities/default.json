{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the desktop shell",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-stat",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-write-file",
    "sql:default",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/reports"
        },
        {
          "path": "$APPDATA/reports/**"
        },
        {
          "path": "$APPDATA/decode-cache"
        },
        {
          "path": "$APPDATA/decode-cache/**"
        }
      ]
    }
  ]
}
