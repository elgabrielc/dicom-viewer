{
    "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "docs/js/**/*.js",
            "docs/css/**/*.css",
            "tests/**/*.js",
            "!docs/js/openjpeg*.js",
            "!!docs/js/vendor"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "globals": ["DicomViewerApp", "CONFIG", "dicomParser", "jpegLossless"],
        "formatter": {
            "quoteStyle": "single"
        }
    },
    "css": {
        "formatter": {
            "quoteStyle": "single"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "off"
            }
        }
    }
}
